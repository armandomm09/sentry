# .env.example — copy to .env and fill in values before running
# Required
JWT_SECRET=change-me-to-a-long-random-string

# Optional face-service tuning (defaults shown)
# FACE_SERVICE_MATCH_THRESHOLD=0.42   # enrollment/photo dedupe only, not live recognition
# FACE_SERVICE_MODEL=buffalo_l
# Live recognition identity hysteresis (see CLAUDE.md, Face Service section)
# FACE_SERVICE_ACQUIRE_THRESHOLD=0.45   # similarity to acquire a track identity
# FACE_SERVICE_KEEP_THRESHOLD=0.35      # similarity to keep an acquired identity
# FACE_SERVICE_ACQUIRE_VOTES=3
# FACE_SERVICE_MIN_VOTE_FACE_PX=48
# FACE_SERVICE_MIN_VOTE_DET_SCORE=0.6
# FACE_SERVICE_UNKNOWN_MIN_AGE_S=3.0
# FACE_SERVICE_UNKNOWN_MIN_VOTES=5
